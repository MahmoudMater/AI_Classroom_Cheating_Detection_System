generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  PROCTOR
  ADMIN
}

enum SessionStatus {
  ACTIVE
  ENDED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  name      String?
  role      UserRole      @default(STUDENT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("users")
}

model Exam {
  id          String        @id @default(cuid())
  code        String?       @unique
  title       String
  description String?
  startTime   DateTime?
  endTime     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("exams")
}

model ExamSession {
  id            String         @id @default(cuid())
  sessionId     String         @unique
  examId        String?
  studentId     String?
  videoSource   String?
  status        SessionStatus  @default(ACTIVE)
  startedAt     DateTime       @default(now())
  endedAt       DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  alerts        Alert[]
  snapshots     Snapshot[]
  detectionLogs DetectionLog[]

  @@map("exam_sessions")
}

model Alert {
  id          String      @id @default(cuid())
  sessionId   String
  eventType   String
  confidence  Float
  severity    Severity    @default(MEDIUM)
  status      String      @default("new")
  snapshotUrl String?
  metadata    Json?
  createdAt   DateTime    @default(now())
  session     ExamSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("alerts")
}

model Snapshot {
  id         String      @id @default(cuid())
  sessionId  String
  imagePath  String
  eventType  String
  timestamp  DateTime    @default(now())
  createdAt  DateTime    @default(now())
  session    ExamSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@map("snapshots")
}

model DetectionLog {
  id            String      @id @default(cuid())
  sessionId     String
  headDirection String?
  phoneDetected Boolean?
  movementLevel String?
  movementScore Float?
  rawDetections Json?
  timestamp     DateTime    @default(now())
  createdAt     DateTime    @default(now())
  session       ExamSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@map("detection_logs")
}
